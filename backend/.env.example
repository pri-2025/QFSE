# ── Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────
DATABASE_URL="postgresql://qfse_user:qfse_password@localhost:5432/qfse_db?schema=public"

